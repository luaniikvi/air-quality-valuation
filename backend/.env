# Backend env example

# Ports
API_PORT=8080

# WebSocket
# Recommended for deployment: do NOT set WS_PORT (WS will attach to the same HTTP port at /ws)
WS_PATH=/ws
# Legacy / local: uncomment to run WS on a separate port
# WS_PORT=8080

# MQTT
MQTT_URL=mqtt://broker.emqx.io:1883
TOPIC_SUB=hluan/aqm/+/telemetry

# Optional: lock CORS to your frontend domain(s), comma-separated
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# MySQL (optional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=3014
MYSQL_DATABASE=air_quality_monitor

OFFLINE_AFTER_SEC=15
