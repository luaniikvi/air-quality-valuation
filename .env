## Frontend
# Production: deploy behind the same domain -> you can leave these empty
# (frontend will use /api and /ws automatically).
#
# Local dev (option A - no proxy):
# VITE_API_BASE=http://localhost:8080/api


VITE_USE_MOCK=false

# Optional: override WS URL (default: same origin + /ws)
# VITE_WS_URL=ws://localhost:8080/ws

TOPIC_SUB=hluan/aqm/+/telemetry
API_PORT=8080

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=3014
MYSQL_DATABASE=air_quality_monitor

OFFLINE_AFTER_SEC=15