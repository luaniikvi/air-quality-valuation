# Frontend env example
#
# Production (recommended): deploy frontend + backend behind the same domain.
# In that case you can OMIT VITE_API_BASE and the app will use relative '/api'.
#
# Local dev option A (no proxy):
# VITE_API_BASE=http://localhost:8080/api
#
# Local dev option B (recommended): use Vite proxy (default), keep VITE_API_BASE empty.

# Use mock data if backend not ready
VITE_USE_MOCK=true

# Optional: override WS URL (defaults to same origin + '/ws')
# VITE_WS_URL=ws://localhost:8080/ws

# Backend HTTP port for local dev
# - Backend listens on this port (API_PORT)
# - Vite dev proxy will forward /api and /ws to this port by default
API_PORT=8080
